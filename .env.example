# =============================================================================
# CEO Assistant — .env.example
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o controle de versão (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# EVOLUTION API — Gateway WhatsApp
# -----------------------------------------------------------------------------

# Chave de autenticação global da Evolution API (defina uma string segura)
EVOLUTION_API_KEY=sua_chave_secreta_aqui_troque_isso

# Nome da instância Baileys criada na Evolution API
EVOLUTION_INSTANCE_NAME=WHATSAPP-BAILEYS

# URL base da Evolution API acessível pelo app (dentro da rede Docker, use o nome do serviço)
# Em produção ou com ngrok, ajuste para a URL pública
EVOLUTION_BASE_URL=http://evolution_api:8080

# Porta exposta ao host para acessar o dashboard/API da Evolution API
EVOLUTION_HOST_PORT=8080

# Porta exposta ao host para o webhook receiver FastAPI
APP_HOST_PORT=8000

# -----------------------------------------------------------------------------
# SEGURANÇA — Controle de acesso
# -----------------------------------------------------------------------------

# Número do WhatsApp do CEO no formato internacional com sufixo @s.whatsapp.net
# Exemplo: 5511999999999@s.whatsapp.net
CEO_WHATSAPP_NUMBER=55XXXXXXXXXXX@s.whatsapp.net

# -----------------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL (usado pela Evolution API)
# -----------------------------------------------------------------------------

POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution_pass_troque_isso
POSTGRES_DB=evolution

# DSN do PostgreSQL para uso direto pela app (opcional — para skill_vendas, etc.)
# Deixe vazio se não usar PostgreSQL nas skills
POSTGRES_APP_DSN=postgresql://user:senha@postgres:5432/nome_banco

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

REDIS_PASSWORD=redis_pass_troque_isso

# -----------------------------------------------------------------------------
# LLM — Configuração do modelo de linguagem
# -----------------------------------------------------------------------------

# Provedor: "ollama" | "openai" | "anthropic"
LLM_PROVIDER=ollama

# Nome do modelo (depende do provedor)
# Ollama: llama3, mistral, gemma2, etc.
# OpenAI: gpt-4o, gpt-4o-mini
# Anthropic: claude-3-5-sonnet-20241022
LLM_MODEL=llama3

# URL do Ollama (quando rodando no host, use host.docker.internal dentro do Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Chave da API OpenAI (deixe vazio se não usar)
OPENAI_API_KEY=

# Chave da API Anthropic/Claude (deixe vazio se não usar)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# RAG — Configuração do banco vetorial e embeddings
# -----------------------------------------------------------------------------

# Diretório de persistência do ChromaDB (mapeado como volume Docker)
CHROMA_PERSIST_DIR=/data/chroma

# -----------------------------------------------------------------------------
# LOGS — SQLite para registro de interações
# -----------------------------------------------------------------------------

SQLITE_DB_PATH=/data/sqlite/interactions.db

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# RATE LIMITING — Proteção básica contra abuso
# -----------------------------------------------------------------------------

# Máximo de requisições permitidas por janela de tempo (por número de telefone)
RATE_LIMIT_REQUESTS=10

# Janela de tempo em segundos para o rate limiting
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# GOOGLE SHEETS — Conector de dados (opcional)
# -----------------------------------------------------------------------------

# Caminho para o arquivo de credenciais da conta de serviço do Google
# Coloque o arquivo JSON em ./secrets/google_credentials.json
GOOGLE_SHEETS_CREDENTIALS_PATH=/app/secrets/google_credentials.json

# ID da planilha do Google Sheets com dados financeiros
GOOGLE_SHEETS_SPREADSHEET_ID=
